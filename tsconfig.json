{
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"declaration": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"incremental": true,
		"module": "commonjs",
		"outDir": "./dist",
		"removeComments": true,
		"resolveJsonModule": true,
		"rootDir": "./src",
		"sourceMap": true,
		"target": "es2017"
	}
}
